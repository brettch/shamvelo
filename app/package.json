{
  "name": "shamvelo",
  "version": "0.0.1",
  "description": "Shambolique Strava Statistics Analysis",
  "author": {
    "name": "Brett Henderson",
    "email": "brett@bretth.com",
    "url": "http://www.bretth.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:brettch/shamvelo.git"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest dist",
    "test:watch": "jest --watch",
    "strava:openapi": "mkdir -p openapi && curl https://developers.strava.com/swagger/swagger.json -o openapi/strava.json",
    "strava:generate": "npx openapi-generator-cli generate --generator-name typescript-fetch --input-spec openapi/strava.json --output src/strava --additional-properties importFileExtension=.js,supportsES6=true --skip-validate-spec"
  },
  "type": "module",
  "dependencies": {
    "@google-cloud/firestore": "8.6.0",
    "body-parser": "2.2.2",
    "date-fns": "4.4.0",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-handlebars": "9.0.1",
    "moment": "2.30.1",
    "morgan": "1.11.0",
    "strava-v3": "4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@openapitools/openapi-generator-cli": "2.34.0",
    "@tsconfig/node24": "24.0.4",
    "@types/cookies": "0.9.2",
    "@types/eslint__js": "8.42.3",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/morgan": "1.9.10",
    "eslint": "10.4.1",
    "jest": "30.4.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1"
  }
}
