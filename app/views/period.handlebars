<div class="d-flex align-items-center justify-content-between mb-3">
  <h1 class="mb-0">{{displayName}}</h1>
  <div class="nav-links">
    {{#if previous includeZero=true}}<a href="./{{previous}}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-chevron-left"></i> Previous</a>{{/if}}
    {{#if next}}<a href="./{{next}}" class="btn btn-outline-secondary btn-sm">Next <i class="bi bi-chevron-right"></i></a>{{/if}}
  </div>
</div>

<h2 class="mb-3"><i class="bi bi-trophy me-2"></i>Yearly Points</h2>
{{#with points}}
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Total</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each total}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Distance</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each distance}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Elevation</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each elevation}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Moving Time <span class="text-muted fw-normal">(excluded from total)</span></div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each movingTime}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Activity Count <span class="text-muted fw-normal">(excluded from total)</span></div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each activityCount}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Active Day Count</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each activeDayCount}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Eddington Number <span class="text-muted fw-normal">(excluded from total)</span></div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each eddingtonNumber}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Average Speed</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each averageSpeed}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Longest Ride</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each longestRide}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Fastest Ride</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Points</th></tr>
          </thead>
          <tbody>
            {{#each fastestRide}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
{{/with}}

<h2 class="mb-3 mt-4"><i class="bi bi-bar-chart me-2"></i>This Period</h2>
{{#with summary}}
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Distance</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Distance</th></tr>
          </thead>
          <tbody>
            {{#each distance}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresAsKilometres this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Elevation</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Elevation</th></tr>
          </thead>
          <tbody>
            {{#each elevation}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresAsMetres this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Moving Time <span class="text-muted fw-normal">(excluded from points)</span></div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Duration</th></tr>
          </thead>
          <tbody>
            {{#each movingTime}}
            <tr><td>{{this.athlete.name}}</td><td>{{secondsAsHours this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Activity Count <span class="text-muted fw-normal">(excluded from points)</span></div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Count</th></tr>
          </thead>
          <tbody>
            {{#each activityCount}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Active Day Count</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Count</th></tr>
          </thead>
          <tbody>
            {{#each activeDayCount}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Eddington Number <span class="text-muted fw-normal">(excluded from points)</span></div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Count</th></tr>
          </thead>
          <tbody>
            {{#each eddingtonNumber}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Average Speed</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Speed</th></tr>
          </thead>
          <tbody>
            {{#each averageSpeed}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresPerSecondAsKmh this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Longest Ride</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Ride</th></tr>
          </thead>
          <tbody>
            {{#each longestRide}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresAsKilometres this.value}} (<a href="https://www.strava.com/activities/{{this.ride.id}}">View on Strava</a>)</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Fastest Ride</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Speed</th></tr>
          </thead>
          <tbody>
            {{#each fastestRide}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresPerSecondAsKmh this.value}} (<a href="https://www.strava.com/activities/{{this.ride.id}}">View on Strava</a>)</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
{{/with}}

<div class="mt-3 nav-links">
  {{#if previous includeZero=true}}<a href="./{{previous}}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-chevron-left"></i> Previous</a>{{/if}}
  {{#if next}}<a href="./{{next}}" class="btn btn-outline-secondary btn-sm">Next <i class="bi bi-chevron-right"></i></a>{{/if}}
</div>
