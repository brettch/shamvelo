<div class="d-flex align-items-center justify-content-between mb-3">
  <h1 class="mb-0">{{displayName}}</h1>
  <div class="nav-links">
    {{#if previous}}<a href="./{{previous}}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-chevron-left"></i> Previous</a>{{/if}}
    {{#if next}}<a href="./{{next}}" class="btn btn-outline-secondary btn-sm">Next <i class="bi bi-chevron-right"></i></a>{{/if}}
  </div>
</div>

<div class="card jersey-table">
  <div class="card-header">
    <i class="bi bi-trophy me-2"></i>Jersey Leaders
  </div>
  <div class="card-body p-0">
    <table class="table table-striped mb-0">
      <thead>
        <tr>
          <th>Jersey</th>
          <th>Leader</th>
          <th>Result</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><span class="jersey-dot" style="background:#f5c518;"></span> Yellow</td>
          <td>{{summary.distance.[0].athlete.name}}</td>
          <td>{{metresAsKilometres summary.distance.[0].value}} km</td>
        </tr>
        <tr>
          <td><span class="jersey-dot" style="background:#1b6b2e;"></span> Dark Green (Monthly Points) <a href="./{{year}}/month" class="ms-1"><i class="bi bi-box-arrow-up-right"></i></a></td>
          <td>{{points.month.total.[0].athlete.name}}</td>
          <td>{{points.month.total.[0].value}} pts</td>
        </tr>
        <tr>
          <td><span class="jersey-dot" style="background:#4caf50;"></span> Light Green (Weekly Points) <a href="./{{year}}/week" class="ms-1"><i class="bi bi-box-arrow-up-right"></i></a></td>
          <td>{{points.week.total.[0].athlete.name}}</td>
          <td>{{points.week.total.[0].value}} pts</td>
        </tr>
        <tr>
          <td><span class="jersey-dot" style="background:#fff;border-color:#ccc;"></span> Polka Dot</td>
          <td>{{summary.elevation.[0].athlete.name}}</td>
          <td>{{metresAsMetres summary.elevation.[0].value}} m</td>
        </tr>
        <tr>
          <td><span class="jersey-dot" style="background:#6c757d;"></span> Ironman (Longest Ride)</td>
          <td>{{summary.longestRide.[0].athlete.name}}</td>
          <td>{{metresAsKilometres summary.longestRide.[0].value}} km (<a href="https://www.strava.com/activities/{{summary.longestRide.[0].ride.id}}">View on Strava</a>)</td>
        </tr>
        <tr>
          <td><span class="jersey-dot" style="background:#0d6efd;"></span> Alley Cat (Fastest Average)</td>
          <td>{{summary.averageSpeed.[0].athlete.name}}</td>
          <td>{{metresPerSecondAsKmh summary.averageSpeed.[0].value}} km/h</td>
        </tr>
        <tr>
          <td><span class="jersey-dot" style="background:#dc3545;"></span> VO2 Max (Fastest Average For Single Ride Over 10km)</td>
          <td>{{summary.fastestRide.[0].athlete.name}}</td>
          <td>{{metresPerSecondAsKmh summary.fastestRide.[0].value}} km/h (<a href="https://www.strava.com/activities/{{summary.fastestRide.[0].ride.id}}">View on Strava</a>)</td>
        </tr>
        <tr>
          <td><span class="jersey-dot" style="background:#2d8a4e;"></span> Green Warrior (Most Number Of Days Ridden)</td>
          <td>{{summary.activeDayCount.[0].athlete.name}}</td>
          <td>{{summary.activeDayCount.[0].value}} days</td>
        </tr>
        <tr>
          <td><span class="jersey-dot" style="background:#6f42c1;"></span> Astrophysicist (Highest Eddington Number)</td>
          <td>{{summary.eddingtonNumber.[0].athlete.name}}</td>
          <td>{{summary.eddingtonNumber.[0].value}}</td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<h2 class="mb-3"><i class="bi bi-bar-chart me-2"></i>Details</h2>
{{#with summary}}
<div class="row g-3">
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Distance</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Distance</th></tr>
          </thead>
          <tbody>
            {{#each distance}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresAsKilometres this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Elevation</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Elevation</th></tr>
          </thead>
          <tbody>
            {{#each elevation}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresAsMetres this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Moving Time</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Duration</th></tr>
          </thead>
          <tbody>
            {{#each movingTime}}
            <tr><td>{{this.athlete.name}}</td><td>{{secondsAsHours this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Activity Count</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Count</th></tr>
          </thead>
          <tbody>
            {{#each activityCount}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Active Day Count</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Count</th></tr>
          </thead>
          <tbody>
            {{#each activeDayCount}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Eddington Number</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Count</th></tr>
          </thead>
          <tbody>
            {{#each eddingtonNumber}}
            <tr><td>{{this.athlete.name}}</td><td>{{this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Average Speed</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Speed</th></tr>
          </thead>
          <tbody>
            {{#each averageSpeed}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresPerSecondAsKmh this.value}}</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Longest Ride</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Ride</th></tr>
          </thead>
          <tbody>
            {{#each longestRide}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresAsKilometres this.value}} (<a href="https://www.strava.com/activities/{{this.ride.id}}">View on Strava</a>)</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card">
      <div class="card-header">Fastest Ride</div>
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr><th>Athlete</th><th>Speed</th></tr>
          </thead>
          <tbody>
            {{#each fastestRide}}
            <tr><td>{{this.athlete.name}}</td><td>{{metresPerSecondAsKmh this.value}} (<a href="https://www.strava.com/activities/{{this.ride.id}}">View on Strava</a>)</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
{{/with}}

<div class="mt-3 nav-links">
  {{#if previous}}<a href="./{{previous}}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-chevron-left"></i> Previous</a>{{/if}}
  {{#if next}}<a href="./{{next}}" class="btn btn-outline-secondary btn-sm">Next <i class="bi bi-chevron-right"></i></a>{{/if}}
</div>
